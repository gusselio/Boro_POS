<Window x:Class="BoroPOS.Views.POSWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BoroPOS.Views"
        mc:Ignorable="d"
        Title="POSWindow" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!--LOGO BORO-->
            <Image 
                HorizontalAlignment="Center" 
                Height="62" 
                Margin="0,10,0,40" 
                VerticalAlignment="Top" 
                Width="144" 
                Source="/Assets/BOROLogo.png"
                Grid.Row="0"/>
            
            <!--BOTONES-->
            <StackPanel Grid.Row="1" Margin="10,20,10,0"  VerticalAlignment="Top">
                <!-- Inicio -->
                <Button Style="{StaticResource BotonNav}" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/HomeIcon.png" Width="25" Height="25"/>
                        <TextBlock Text="Inicio" VerticalAlignment="Center"
                            Margin="10,0,0,0" FontSize="20" FontFamily="Trebuchet MS"/>
                    </StackPanel>
                </Button>

                <!-- Menú -->
                <Button Style="{StaticResource BotonNav}" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/MenuIcon.png" Width="25" Height="25"/>
                        <TextBlock Text="Menú" VerticalAlignment="Center"
                            Margin="10,0,0,0" FontSize="20" FontFamily="Trebuchet MS"/>
                    </StackPanel>
                </Button>
                
                <!-- Ordenes -->
                <Button Style="{StaticResource BotonNav}" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/OrderIcon.png" Width="25" Height="25"/>
                        <TextBlock Text="Ordenes" VerticalAlignment="Center"
                            Margin="10,0,0,0" FontSize="20" FontFamily="Trebuchet MS"/>
                    </StackPanel>
                </Button>
                
                <!-- Historial -->
                <Button Style="{StaticResource BotonNav}" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/HistoryIcon.png" Width="25" Height="25"/>
                        <TextBlock Text="Historial" VerticalAlignment="Center"
                            Margin="10,0,0,0" FontSize="20" FontFamily="Trebuchet MS"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>

        <Grid Grid.Column="1"/>
        <Grid Grid.Column="2"/>
    </Grid>
</Window>
