<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="BoroPOS.Views.LoginWindow"
        Title="Login"
        Width="1200"
        Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="35" Background="#FFA16C" >
        <Grid Margin="-10,-10,10,10">
            <!-- Filas: barra arriba, contenido abajo -->
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILA 0: Barra superior -->

            <!-- FILA 1: Tu contenido actual -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="443*"/>
                    <ColumnDefinition Width="757*"/>
                </Grid.ColumnDefinitions>
                <Border 
                    CornerRadius="20"
                    Background="#FFEBCEAB"
                    Padding="10,0" 
                    Margin="236,36,73,252" 
                    Grid.Column="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" 
                          Opacity="0.21" 
                          ShadowDepth="7"
                          Color="Black"/>
                    </Border.Effect>
                </Border>
                <TextBlock HorizontalAlignment="Left" Margin="302,47,0,0" TextWrapping="Wrap" Text="Inicio de Sesión" VerticalAlignment="Top" FontSize="45" FontFamily="Yu Gothic UI Semibold" Grid.Column="1"/>
                <Border CornerRadius="5"
                    Background="White"
                    Padding="10,0" Margin="258,177,248,357" Grid.Column="1">
                    <TextBox x:Name="txtEmpleadoId"
                        PreviewTextInput="SoloNumeros"
                        BorderThickness="0"
                        Background="White"
                        VerticalAlignment="Center"
                        Height="20" 
                        FontSize="15"/>
                </Border>
                <Label Content="No. Empleado" HorizontalAlignment="Left" Margin="258,135,0,0" VerticalAlignment="Top" FontSize="20" FontFamily="Yu Gothic UI Semibold" Grid.Column="1"/>
                <Label Content="Contraseña" HorizontalAlignment="Left" Margin="258,213,0,0" VerticalAlignment="Top" FontSize="20" FontFamily="Yu Gothic UI Semibold" Grid.Column="1"/>
                <Border CornerRadius="5"
                    Background="White"
                    Padding="10,0" Margin="258,255,248,279" Grid.Column="1">
                    <Grid>
                        <!-- Contraseña oculta -->
                        <PasswordBox x:Name="txtPasswordOculto"
                            PasswordChar="●" 
                            Margin="0,5,-10,5" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Height="20"/>

                        <!-- Contraseña visible — oculto por defecto -->
                        <TextBox x:Name="txtPasswordVisible"
                            Visibility="Collapsed"
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Height="20"/>

                        <!-- Botón ojo -->
                        <Button Content="👁"
                            Click="MostrarPassword_Click" 
                            Background="White" 
                            BorderBrush="Transparent" 
                            BorderThickness="0" 
                            HorizontalAlignment="Right" 
                            Width="30"/>
                    </Grid>
                </Border>
                <Grid Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="555" Margin="10,10,0,0" VerticalAlignment="Stretch" Width="590">
                    <Viewbox xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" Stretch="Uniform">
                        <Canvas x:Name="svg4" Width="301" Height="265">
                            <Canvas.RenderTransform>
                                <TranslateTransform X="0" Y="0"/>
                            </Canvas.RenderTransform>
                            <!--Unknown tag: sodipodi:namedview-->
                            <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="path2" Fill="#FFFEF9F9" HorizontalAlignment="Left" Canvas.Top="-9.07" VerticalAlignment="Center" Height="288" Stretch="Fill" Width="321">
                                <Path.Data>
                                    <PathGeometry Figures="M186.5 0H0V255C0 260.523 4.47717 265 10 265H266.085C267.883 265 269.56 264.009 270.438 262.44C306.51 197.989 306.758 159.701 288 137C268.994 114 233 104.5 201 67.5C183.598 47.3784 177.644 11.3333 186.5 0Z" FillRule="NonZero"/>
                                </Path.Data>
                            </Path>
                            <Border CornerRadius="20" 
                                Width="186" 
                                Height="259" Canvas.Left="7" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Top="-9" RenderTransformOrigin="0.38,0.532">
                                <Border.Background>
                                    <ImageBrush ImageSource="/Views/IMG_4756.jpg" 
                                        Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                            <Border CornerRadius="20" 
                                Width="90" 
                                Height="153" Canvas.Left="178" Canvas.Top="122" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform AngleY="-0.381"/>
                                        <RotateTransform/>
                                        <TranslateTransform Y="0.299"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Background>
                                    <ImageBrush ImageSource="/Views/Gemini_Generated_Image_cp55p3cp55p3cp55.png" 
                                        Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>


                        </Canvas>
                    </Viewbox>
                </Grid>
            </Grid>
            <Button  
                Content="ENTRAR" 
                Margin="981,237,88,272" 
                Grid.Row="1" 
                Style="{StaticResource BotonRedondeado}" 
                FontFamily="Bahnschrift" 
                FontSize="25" 
                Click="Entrar_Click"/>
            <Border Grid.Row="0"
                    Background="White"
                    MouseDown="BarraTitulo_MouseDown" 
                    Margin="10,10,-10,555" 
                    Grid.RowSpan="2">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="—" Width="35" Height="35"
                            Click="Minimizar_Click"/>
                    <Button Content="✕" Width="35" Height="35"
                            Click="Cerrar_Click"/>
                </StackPanel>
            </Border>
            <Label Content="© 2026 Boro POS" HorizontalAlignment="Left" Margin="23,539,0,0" Grid.Row="1" VerticalAlignment="Top"/>

        </Grid>
    </Border>
</Window>